# Prevent Cloudflare CDN edge caching for critical PWA files
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/workbox-*.js
  Cache-Control: no-cache, no-store, must-revalidate

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

# Also handle root path (navigations)
/
  Cache-Control: no-cache, no-store, must-revalidate

# Allow hashed assets to be cached (they have unique filenames)
/assets/*
  Cache-Control: public, max-age=31536000, immutable















