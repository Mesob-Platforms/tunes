<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="@drawable/widget_background">

    <FrameLayout
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/widget_album_bg"
        android:clipToOutline="true">

        <ImageView
            android:id="@+id/widget_album_art"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="Album art" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:layout_marginEnd="8dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Not Playing"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.01"
            android:maxLines="1"
            android:ellipsize="marquee"
            android:singleLine="true" />

        <TextView
            android:id="@+id/widget_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tunes"
            android:textColor="#999999"
            android:textSize="12sp"
            android:fontFamily="sans-serif"
            android:maxLines="1"
            android:ellipsize="end"
            android:singleLine="true"
            android:layout_marginTop="1dp" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/widget_prev"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:src="@drawable/ic_notif_prev"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Previous"
        android:scaleType="centerInside"
        android:padding="7dp"
        android:layout_marginEnd="2dp" />

    <ImageButton
        android:id="@+id/widget_play_pause"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:src="@drawable/ic_notif_play"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Play or Pause"
        android:scaleType="centerInside"
        android:padding="6dp"
        android:layout_marginEnd="2dp" />

    <ImageButton
        android:id="@+id/widget_next"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:src="@drawable/ic_notif_next"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Next"
        android:scaleType="centerInside"
        android:padding="7dp" />

</LinearLayout>
